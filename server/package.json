{
  "name": "server",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon index.js",
    "start": "node index.js",
    "test": "node --experimental-test-module-mocks --test",
    "lint": "eslint . --ext js,cjs --report-unused-disable-directives --max-warnings 0",
    "depcruise": "depcruise src --config .dependency-cruiser.js",
    "depcruise:validate": "depcruise src --config .dependency-cruiser.js --output-type err-long",
    "depcruise:graph": "depcruise src --config .dependency-cruiser.js --output-type dot | dot -T svg > dependency-graph.svg",
    "depcruise:circular": "depcruise src --config .dependency-cruiser.js --output-type err-long --include-only \"^src\" 2>&1 | grep -A3 'no-circular' || echo 'No circular dependencies found'"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@monaco-editor/react": "^4.7.0",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.1",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.12.0",
    "mongodb": "^7.2.0",
    "mongoose": "^9.6.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "openai": "^4.104.0",
    "pdf-parse": "^2.4.5",
    "rate-limit-redis": "^5.0.0",
    "redis": "^5.12.1",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.21.0",
    "y-websocket": "^1.5.0",
    "yjs": "^13.6.31",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "dependency-cruiser": "^16.10.1",
    "mongodb-memory-server": "^11.2.0",
    "eslint": "^8.57.1",
    "nodemon": "^3.1.14",
    "socket.io-client": "^4.8.3"
  }
}
